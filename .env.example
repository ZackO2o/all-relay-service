# =============================================
#  ALL Relay Service 环境变量配置
# =============================================

# ---- 核心服务 ----
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
TRUST_PROXY=false
LOG_LEVEL=info

# ---- 密钥（必填） ----
JWT_SECRET=your-jwt-secret-at-least-32-chars
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLE_TLS=false

# ---- 管理员账号 ----
ADMIN_USERNAME=ar_admin
ADMIN_PASSWORD=your-admin-password

# ---- API Key 配置 ----
API_KEY_PREFIX=ar_

# ---- TLS Proxy（可选）- 使用 Go uTLS 代理绕过 Cloudflare TLS 指纹检测
# 当设置后，Claude 请求会通过这个代理转发，获得 Chrome JA3 TLS 指纹 + 设备伪装
# 推荐部署：https://github.com/ZackO2o/all-relay-service/tree/main/cliproxy-tls
# CLAUDE_TLS_PROXY=https://localhost:9200
# NODE_TLS_REJECT_UNAUTHORIZED=0    # 如果使用自签名证书需要此设置

# ---- 代理配置 ----
DEFAULT_PROXY_TIMEOUT=60000
PROXY_KEEP_ALIVE=true
PROXY_MAX_SOCKETS=256
PROXY_USE_IPV4=false
MAX_PROXY_RETRIES=3

# ---- 请求超时 ----
REQUEST_TIMEOUT=120000
REQUEST_MAX_SIZE_MB=10

# ---- 粘性会话 ----
STICKY_SESSION_TTL_HOURS=2

# ---- 清理间隔（秒） ----
CLEANUP_INTERVAL=300

# ---- 账户管理 ----
CLAUDE_CONSOLE_BLOCKED_HANDLING_MINUTES=30
CLAUDE_5H_WARNING_MAX_NOTIFICATIONS=3

# ---- 用户管理 ----
USER_MANAGEMENT_ENABLED=false
MAX_API_KEYS_PER_USER=10
DEFAULT_USER_ROLE=user

# ---- Webhook 通知 ----
WEBHOOK_ENABLED=false
WEBHOOK_URLS=
WEBHOOK_TIMEOUT=15000
WEBHOOK_RETRIES=3

# ---- 账单事件 ----
BILLING_EVENTS_ENABLED=false
BALANCE_SCRIPT_ENABLED=false

# ---- 调试 ----
DEBUG_HTTP_TRAFFIC=false

# ---- LDAP（可选） ----
# LDAP_ENABLED=true
# LDAP_URL=ldap://localhost:389
# LDAP_BIND_DN=cn=admin,dc=example,dc=com
# LDAP_BIND_PASSWORD=password
# LDAP_SEARCH_BASE=dc=example,dc=com
# LDAP_SEARCH_FILTER=(uid={{username}})
# LDAP_TLS_REJECT_UNAUTHORIZED=true

# ---- Claude API（可选） ----
# CLAUDE_API_URL=https://api.anthropic.com
# CLAUDE_API_VERSION=2023-06-01
# CLAUDE_BETA_HEADER=

# ---- Gemini OAuth（可选） ----
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=
# GEMINI_OAUTH_REDIRECT_URI=

# ---- Antigravity OAuth（可选） ----
# ANTIGRAVITY_API_URL=
# ANTIGRAVITY_USER_AGENT=
# ANTIGRAVITY_OAUTH_CLIENT_ID=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=
# ANTIGRAVITY_OAUTH_REDIRECT_URI=

# ---- AWS Bedrock（可选） ----
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20241022
